name: Crypto & Macro News Bot

on:
  schedule:
    - cron: "*/30 * * * *"   # every 30 minutes (UTC)
  workflow_dispatch: {}       # allow manual trigger from GitHub UI

permissions:
  contents: write

jobs:
  run-bot:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: pip install -r requirements.txt

      - name: Run bot
        env:
          DISCORD_WEBHOOK_URL: ${{ secrets.DISCORD_WEBHOOK_URL }}
        run: python bot.py

      - name: Commit updated state file
        run: |
          git config --global user.name "news-bot"
          git config --global user.email "news-bot@users.noreply.github.com"
          git add sent_news.json
          git diff --staged --quiet || git commit -m "update sent news state [skip ci]"
          git push
